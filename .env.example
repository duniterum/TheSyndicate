# Avalanche RPC endpoints (optional)
#
# Preferred production variable:
#   VITE_AVALANCHE_RPC_URL=<QuickNode Avalanche C-Chain HTTPS endpoint>
#
# Important: VITE_ variables are public browser values. The URL is not rendered
# in the UI, but it is still visible in the built frontend bundle and browser
# network traffic. Use a provider endpoint that is safe to expose and restrict it
# by domain/origin in the provider dashboard when available.
#
# Leave blank to use the built-in public fallback behavior:
#   primary  = https://api.avax.network/ext/bc/C/rpc
#   fallback = https://rpc.ankr.com/avalanche
#
# Backward-compatible aliases:
#   VITE_AVALANCHE_RPC_PRIMARY  can also provide a primary RPC.
#   VITE_AVALANCHE_RPC_FALLBACK can replace the public Ankr fallback.
VITE_AVALANCHE_RPC_URL=
VITE_AVALANCHE_RPC_PRIMARY=
VITE_AVALANCHE_RPC_FALLBACK=
